# Server runtime
NODE_ENV=development
PORT=5001

# PostgreSQL connection used by Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hostin?schema=public

# JWT signing secret for org users and platform admins.
# Replace with a long random value before deploying.
JWT_SECRET=replace_with_a_long_random_secret

# Exact comma-separated browser origins permitted by CORS. Add every custom or
# Vercel preview frontend here; localhost and the production HostIn UI are built in.
CLIENT_ORIGIN=http://localhost:3000,https://host-in-beta.vercel.app

# fatal, error, warn, info, debug, trace, or silent
LOG_LEVEL=info
